{
  "name": "Loan Application Email Notification",
  "nodes": [
    {
      "parameters": {
        "httpMethod": "POST",
        "path": "Loan_Application",
        "options": {}
      },
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 2,
      "position": [
        0,
        0
      ],
      "id": "webhook-node",
      "name": "Webhook Receiver"
    },
    {
      "parameters": {
        "sendTo": "={{ $json.email }}",
        "subject": "=Loan Application Underwriting Result: {{ $json.prediction }}",
        "emailType": "html",
        "html": "=<h3>Hello {{ $json.name }},</h3><p>Thank you for submitting your loan application. Below is the decision generated by the Credence AI underwriting system:</p><table border='1' cellpadding='8' style='border-collapse: collapse;'><tr><td><strong>Applicant Name</strong></td><td>{{ $json.name }}</td></tr><tr><td><strong>Underwriting Verdict</strong></td><td><strong>{{ $json.prediction }}</strong></td></tr><tr><td><strong>Offered Interest Rate</strong></td><td>{{ $json.interest_rate }}%</td></tr><tr><td><strong>Annual Income</strong></td><td>${{ $json.income }}</td></tr><tr><td><strong>Previous Default History</strong></td><td>{{ $json.previous_default }}</td></tr></table><br/><p>Best regards,<br/><strong>Credence Underwriting Portal</strong></p>",
        "options": {}
      },
      "type": "n8n-nodes-base.emailSend",
      "typeVersion": 1,
      "position": [
        250,
        0
      ],
      "id": "email-node",
      "name": "Send Email Notification"
    }
  ],
  "connections": {
    "Webhook Receiver": {
      "main": [
        [
          {
            "node": "Send Email Notification",
            "type": "main",
            "index": 0
          }
        ]
      ]
    }
  },
  "active": true,
  "settings": {
    "executionOrder": "v1"
  }
}
